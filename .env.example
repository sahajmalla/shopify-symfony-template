# Copy this file to .env and fill in values.
# For local development with Shopify CLI, run: shopify app dev
# The CLI will set SHOPIFY_API_KEY and SHOPIFY_API_SECRET automatically.

###> symfony/routing ###
# Base URL of your app (used for webhook callback URLs and URL generation). Must match your Shopify app URL.
DEFAULT_URI=https://your-app-url.com
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Production: use a real database (PostgreSQL/MySQL). Include serverVersion in the URL.
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?serverVersion=16&charset=utf8"
# DATABASE_URL="mysql://user:pass@host:3306/dbname?serverVersion=8.0&charset=utf8mb4"
# Local dev (optional): SQLite
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> shopify/shopify-app-php ###
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_OLD_API_SECRET=
# Optional: base64-encoded 32-byte key for encrypting tokens at rest (openssl rand -base64 32)
SHOPIFY_TOKEN_ENCRYPTION_KEY=
###< shopify/shopify-app-php ###
